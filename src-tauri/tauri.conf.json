{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Universal Video Cutter",
  "version": "1.0.2",
  "identifier": "com.universal.videocutter",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Universal Video Cutter",
        "width": 1280,
        "height": 780,
        "minWidth": 1280,
        "minHeight": 780,
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost https://asset.localhost data:; media-src 'self' asset: http://asset.localhost https://asset.localhost blob: data:; font-src 'self'; frame-src 'none'; object-src 'none';",
      "assetProtocol": {
        "enable": true,
        "scope": ["**", "$TEMP/**", "$DOWNLOAD/**", "$HOME/**", "$DOCUMENT/**", "$VIDEO/**", "$DESKTOP/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "bin/ffmpeg",
      "bin/ffprobe"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
